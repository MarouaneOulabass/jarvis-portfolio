# ─── Required ─────────────────────────────────────────────────────────
# Anthropic API key (Claude AI) — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Optional ─────────────────────────────────────────────────────────
# Model override (default: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# GitHub token for higher rate limits (5000 req/h vs 60/h unauthenticated)
# Create at https://github.com/settings/tokens (classic, no scopes needed for public repos)
# GITHUB_TOKEN=ghp_xxxxx

# GitHub user to audit (default: MarouaneOulabass)
# GITHUB_USER=MarouaneOulabass

# Public URL for OG images + canonical metadata (production)
# NEXT_PUBLIC_SITE_URL=https://jarvis.example.com
